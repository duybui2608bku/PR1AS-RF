NEXT_PUBLIC_SITE_URL=https://pr1as.com
NEXT_PUBLIC_API_URL=https://api.example.com/api
NEXT_PUBLIC_SOCKET_URL=https://api.example.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# QUAN TRỌNG: Phải khớp với JWT_SECRET của backend SERVER
# Thiếu biến này trong production → Edge middleware không verify được token
# → tất cả protected routes (/chat, /client, /dashboard...) redirect về /login
JWT_SECRET=your-jwt-secret-here
