# Sao chép thành .env và điền giá trị (nhận từ team lead)
# cp SERVER/.env.example SERVER/.env

PORT=3052
NODE_ENV=development

# MongoDB Atlas — nhận URI từ team lead
# QUAN TRỌNG: DB_NAME phải là pr1as_dev, KHÔNG phải pr1as_production (production)
MONGODB_URI=
DB_NAME=pr1as_dev

JWT_SECRET=
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRE=7d

CORS_ORIGIN=http://localhost:3000
CORS_METHODS=GET,POST,PUT,DELETE,PATCH
CORS_CREDENTIALS=true
FRONTEND_URL=http://localhost:3000

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000

MORGAN_FORMAT=dev

SOCKET_PING_TIMEOUT=60000
SOCKET_METHODS=GET,POST

LOG_DIR=logs
ERROR_LOG_FILE=error.log
COMBINED_LOG_FILE=combined.log

# Tùy chọn — để trống vẫn chạy được khi dev local
EMAIL_ACCOUNT=
GOGGLE_APP_PASSWORD=
GOOGLE_CLIENT_ID=

MEDIA_ALLOWED_HOSTS=res.cloudinary.com,images.unsplash.com,cdn.example.com,i.ibytecdn.org
